<% mr_data = @mr_sessions.respond_to?(:data) ? Array(@mr_sessions.data) : [] %>
<% render_data = @render_sessions.respond_to?(:data) ? Array(@render_sessions.data) : [] %>
<% vpn_data = @vpn_sessions.respond_to?(:data) ? Array(@vpn_sessions.data) : [] %>
<% tabs = [
  {id: "mr", label: "Machine Rental", hook: "octa_client.services.mr.list", path: "/services/mr", data: mr_data, error: (@mr_sessions if @mr_sessions.is_a?(OctaSpace::Error))},
  {id: "render", label: "Render", hook: "octa_client.services.render.list", path: "/services/render", data: render_data, error: (@render_sessions if @render_sessions.is_a?(OctaSpace::Error))},
  {id: "vpn", label: "VPN", hook: "octa_client.services.vpn.list", path: "/services/vpn", data: vpn_data, error: (@vpn_sessions if @vpn_sessions.is_a?(OctaSpace::Error))}
] %>
<% active = tabs.find { |tab| tab[:id] == @active_tab } || tabs.first %>
<% active_status = active[:error] ? "error" : "success" %>

<div class="w-full max-w-full space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-lg font-semibold text-slate-100">Services</h1>
      <p class="mt-1 text-sm text-slate-500">
        Available resources for each service type. Uses the Ruby SDK client against the currently selected transport.
      </p>
    </div>
    <div class="flex items-center gap-3">
      <% if playground_mock_active? %>
        <span class="rounded bg-amber-500/15 px-2 py-0.5 text-[11px] font-medium text-amber-400">Mock: <%= playground_mock_scenario %></span>
      <% end %>
      <%= link_to "Refetch", playground_services_path(request.query_parameters.merge(tab: @active_tab)), class: "rounded border border-slate-700 px-3 py-1.5 text-xs text-slate-400 transition-colors hover:border-slate-600 hover:text-slate-200" %>
    </div>
  </div>

  <div class="rounded-lg border border-amber-800/40 bg-amber-500/5 px-4 py-3 text-xs text-amber-400">
    Start mutations (<code>mr.create</code>, <code>render.create</code>, <code>vpn.create</code>) exist on <code>octa_client.services.*</code> but are intentionally not wired up here — use Diagnostics for manual request inspection.
  </div>

  <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
    <div class="flex gap-1 border-b border-slate-800 px-4 pt-2">
      <% tabs.each do |tab| %>
        <%= link_to playground_services_path(request.query_parameters.merge(tab: tab[:id])),
                    class: "px-4 py-2.5 text-sm transition-colors #{@active_tab == tab[:id] ? 'border-b-2 border-cyan-500 text-cyan-400 -mb-px font-medium' : 'text-slate-500 hover:text-slate-300'}" do %>
          <%= tab[:label] %>
        <% end %>
      <% end %>
    </div>

    <div class="space-y-4 px-4 py-4">
      <div class="flex items-center justify-between gap-4">
        <code class="text-[11px] text-violet-400"><%= active[:hook] %></code>
        <span class="text-xs text-slate-500">
          status:
          <span class="text-slate-300"><%= active_status %></span>
        </span>
      </div>

      <% if active[:error] %>
        <%= render "playground/shared/error_card", error: active[:error] %>
      <% else %>
        <div class="space-y-3">
          <div class="text-xs text-slate-500">
            <%= active[:data].is_a?(Array) ? "#{active[:data].length} items" : "#{active[:data].to_h.keys.length} keys" %>
          </div>
          <div class="overflow-hidden rounded-lg border border-slate-800 bg-slate-950/40">
            <%= render "playground/shared/json_viewer", data: active[:data], max_height: "max-h-[32rem]" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg border border-slate-800 bg-slate-900/50 p-4">
    <div class="mb-2 text-[11px] font-medium uppercase tracking-wider text-slate-500">Request Reference</div>
    <%= render "playground/shared/json_viewer", data: {method: "GET", path: active[:path], resource: active[:hook], transport: playground_transport_label}, max_height: "max-h-20" %>
  </div>
</div>
