<% current_data = @current_sessions.respond_to?(:data) ? Array(@current_sessions.data) : nil %>
<% recent_data = @recent_sessions.respond_to?(:data) ? Array(@recent_sessions.data) : nil %>
<% current_error = @current_sessions if @current_sessions.is_a?(OctaSpace::Error) %>
<% recent_error = @recent_sessions if @recent_sessions.is_a?(OctaSpace::Error) %>
<% tabs = [
  {id: "current", label: "Current", description: "Active sessions"},
  {id: "recent", label: "Recent", description: "Last 50 completed + active"}
] %>

<div class="w-full max-w-full space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-lg font-semibold text-slate-100">Sessions</h1>
      <p class="mt-1 text-sm text-slate-500">
        <code class="text-cyan-400">octa_client.sessions.list</code> for discovery, with stop actions wired through <code class="text-cyan-400">octa_client.services.session(uuid).stop</code>.
      </p>
    </div>
    <div class="flex items-center gap-3">
      <% if playground_mock_active? %>
        <span class="rounded bg-amber-500/15 px-2 py-0.5 text-[11px] font-medium text-amber-400">Mock: <%= playground_mock_scenario %></span>
      <% end %>
      <%= link_to "Refetch", playground_sessions_path(request.query_parameters.merge(tab: @active_tab)), class: "rounded border border-slate-700 px-3 py-1.5 text-xs text-slate-400 transition-colors hover:border-slate-600 hover:text-slate-200" %>
    </div>
  </div>

  <% active_data = @active_tab == "recent" ? recent_data : current_data %>
  <% active_error = @active_tab == "recent" ? recent_error : current_error %>
  <% active_recent = @active_tab == "recent" %>
  <% active_hook = active_recent ? "octa_client.sessions.list(recent: true)" : "octa_client.sessions.list" %>
  <% base_query = request.query_parameters.except("stop_uuid") %>
  <% stop_target = current_data&.find { |session| session["uuid"] == @stop_uuid } if @stop_uuid.present? %>
  <% stop_notice = flash[:playground_stop_notice] %>
  <% stop_error = flash[:playground_stop_error] %>

  <% if stop_notice.present? %>
    <div class="rounded-xl border border-emerald-900/40 bg-emerald-500/5 p-4">
      <div class="flex items-start gap-3">
        <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-emerald-400"></span>
        <div class="min-w-0">
          <div class="text-sm font-medium text-emerald-200">Stop request submitted</div>
          <p class="mt-1 text-xs leading-5 text-emerald-200/80 break-words"><%= stop_notice["message"] %></p>
          <% if stop_notice["request_id"].present? %>
            <p class="mt-1 font-mono text-[11px] text-emerald-300/80">request_id: <%= stop_notice["request_id"] %></p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if stop_error.present? %>
    <div class="rounded-xl border border-rose-900/40 bg-rose-500/5 p-4">
      <div class="flex items-start gap-3">
        <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-rose-400"></span>
        <div class="min-w-0">
          <div class="text-sm font-medium text-rose-200">Stop request failed</div>
          <p class="mt-1 text-xs leading-5 text-rose-200/80 break-words"><%= stop_error %></p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
    <div class="flex gap-1 border-b border-slate-800 px-4 pt-2">
      <% tabs.each do |tab| %>
        <%= link_to playground_sessions_path(request.query_parameters.merge(tab: tab[:id])),
                    class: "flex items-center gap-2 px-4 py-2.5 text-sm transition-colors #{@active_tab == tab[:id] ? '-mb-px border-b-2 border-cyan-500 font-medium text-cyan-400' : 'text-slate-500 hover:text-slate-300'}" do %>
          <span><%= tab[:label] %></span>
          <span class="text-[10px] text-slate-600"><%= tab[:description] %></span>
        <% end %>
      <% end %>
    </div>

    <div class="space-y-4 px-4 py-4">
      <div class="flex items-center justify-between gap-4">
        <code class="text-[11px] text-cyan-500"><%= active_hook %></code>
        <span class="text-xs text-slate-500">
          status:
          <span class="text-slate-300"><%= active_error ? "error" : "success" %></span>
        </span>
      </div>

      <% if active_error %>
        <%= render "playground/shared/error_card", error: active_error %>
      <% elsif active_data %>
        <% if active_data.empty? %>
          <div class="rounded-lg border border-dashed border-slate-800 bg-slate-950/40 px-6 py-12 text-center text-sm text-slate-500">
            No <%= active_recent ? "recent" : "active" %> sessions found.
          </div>
        <% else %>
          <div class="overflow-hidden rounded-lg border border-slate-800 bg-slate-950/40">
            <div class="border-b border-slate-800 px-4 py-3 text-xs text-slate-400">
              <%= active_data.length %> session<%= "s" unless active_data.length == 1 %>
            </div>
            <%= render "playground/shared/sessions_table", sessions: active_data, recent: active_recent %>
          </div>
        <% end %>
      <% else %>
        <div class="rounded-lg border border-dashed border-slate-800 bg-slate-950/40 px-6 py-12 text-center text-sm text-slate-500">
          No response available.
        </div>
      <% end %>
    </div>
  </div>

  <% if active_data.present? && !active_error %>
    <div class="rounded-lg border border-slate-800 bg-slate-900/50 p-4">
      <div class="mb-2 text-[11px] font-medium uppercase tracking-wider text-slate-500">Raw JSON</div>
      <%= render "playground/shared/json_viewer", data: active_data, max_height: "max-h-80" %>
    </div>
  <% end %>
</div>

<% if stop_target.present? %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 px-4 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-xl border border-slate-700 bg-slate-900 p-6 shadow-2xl">
      <h3 class="text-sm font-semibold text-slate-100">Stop session?</h3>
      <p class="mt-2 text-xs leading-5 text-slate-400">
        This will stop session <span class="font-mono text-slate-200"><%= stop_target["uuid"] %></span>. This action cannot be undone.
      </p>
      <div class="mt-5 flex justify-end gap-3">
        <%= link_to "Cancel",
                    playground_sessions_path(base_query.merge(tab: @active_tab)),
                    class: "rounded border border-slate-700 px-3 py-1.5 text-xs text-slate-400 transition-colors hover:border-slate-600 hover:text-slate-200" %>
        <%= form_with url: playground_sessions_stop_path, method: :post, local: true do %>
          <%= hidden_field_tag :uuid, stop_target["uuid"] %>
          <%= hidden_field_tag :tab, @active_tab %>
          <%= button_tag "Stop session", type: "submit", class: "rounded bg-red-600 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-red-500" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
