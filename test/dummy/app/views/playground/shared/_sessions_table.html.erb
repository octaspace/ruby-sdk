<%
  service_label = lambda do |service|
    case service.to_s
    when "mr" then "RENTAL"
    when "render" then "RENDER"
    when "vpn" then "VPN"
    else "—"
    end
  end

  service_badge_class = lambda do |service|
    case service.to_s
    when "mr" then "border border-sky-500/30 bg-sky-900/30 text-sky-400"
    when "render" then "border border-orange-500/30 bg-orange-900/30 text-orange-400"
    when "vpn" then "border border-indigo-500/30 bg-indigo-900/30 text-indigo-400"
    else "border border-slate-600/40 bg-slate-700/50 text-slate-400"
    end
  end

  normal_reason = lambda do |reason|
    [0, 1].include?(reason.to_i)
  end

  session_status = lambda do |session, recent_mode|
    if recent_mode && session["termination_reason"].present?
      normal_reason.call(session["termination_reason"]) ? "Normal" : "Error"
    elsif session["is_ready"]
      "Ready"
    elsif session["progress"].present?
      session["progress"]
    else
      session["status"].presence || "Starting"
    end
  end

  status_badge_class = lambda do |session, recent_mode|
    if recent_mode && session["termination_reason"].present?
      normal_reason.call(session["termination_reason"]) ? "border border-emerald-500/30 bg-emerald-500/15 text-emerald-400" : "border border-rose-500/30 bg-rose-500/15 text-rose-400"
    elsif session["is_ready"]
      "border border-emerald-500/30 bg-emerald-500/15 text-emerald-400"
    else
      "border border-amber-500/30 bg-amber-500/15 text-amber-400"
    end
  end
%>

<% show_service = sessions.any? { |s| s["service"].present? } %>

<div class="overflow-x-auto">
  <table class="min-w-[840px] w-full table-auto text-left text-xs">
    <thead>
      <tr class="border-b border-slate-800 text-[11px] uppercase tracking-wider text-slate-500">
        <th class="px-3 py-2 font-medium">Session</th>
        <th class="px-3 py-2 font-medium">Node ID</th>
        <% if show_service %>
          <th class="px-3 py-2 font-medium">Service</th>
        <% end %>
        <th class="px-3 py-2 font-medium">Status</th>
        <th class="px-3 py-2 font-medium">Started</th>
        <th class="px-3 py-2 font-medium">Duration</th>
        <th class="px-3 py-2 font-medium">Traffic ↓/↑</th>
        <% unless recent %>
          <th class="px-3 py-2 font-medium">IP</th>
        <% end %>
        <th class="px-3 py-2 text-right font-medium">Amount</th>
        <% unless recent %>
          <th class="px-3 py-2 text-right font-medium">Action</th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% sessions.each do |session| %>
        <tr class="border-b border-slate-800/60 text-slate-300 transition-colors hover:bg-slate-800/40">
          <td class="px-3 py-2.5 font-mono tabular-nums text-slate-300" title="<%= session["uuid"] %>"><%= playground_truncate(session["uuid"]) %></td>
          <td class="px-3 py-2.5 tabular-nums text-slate-400">#<%= session["node_id"] || "—" %></td>
          <% if show_service %>
            <td class="px-3 py-2.5">
              <span class="inline-flex rounded px-1.5 py-0.5 text-[10px] font-semibold tracking-wide <%= service_badge_class.call(session["service"]) %>"><%= service_label.call(session["service"]) %></span>
            </td>
          <% end %>
          <td class="px-3 py-2.5">
            <span class="inline-flex rounded px-1.5 py-0.5 text-[10px] font-medium <%= status_badge_class.call(session, recent) %>"><%= session_status.call(session, recent) %></span>
          </td>
          <td class="px-3 py-2.5 tabular-nums text-slate-400"><%= playground_format_datetime(session["started_at"]) %></td>
          <td class="px-3 py-2.5 tabular-nums text-slate-400"><%= playground_format_duration(session["duration"]) %></td>
          <td class="px-3 py-2.5 tabular-nums text-slate-400"><%= playground_format_bytes(session["rx"]) %> / <%= playground_format_bytes(session["tx"]) %></td>
          <% unless recent %>
            <td class="px-3 py-2.5 font-mono text-slate-400"><%= session["public_ip"] || session["ip"] || "—" %></td>
          <% end %>
          <td class="px-3 py-2.5 text-right tabular-nums text-slate-400"><%= session["charge_amount"] || "—" %></td>
          <% unless recent %>
            <td class="px-3 py-2.5 text-right">
              <%= link_to "Stop",
                          playground_sessions_path(request.query_parameters.except("stop_uuid").merge(tab: "current", stop_uuid: session["uuid"])),
                          class: "rounded border border-red-800/50 px-2 py-0.5 text-[11px] text-red-500 transition-colors hover:border-red-600 hover:text-red-400" %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
