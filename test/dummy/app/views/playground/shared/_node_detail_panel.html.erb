<% node_tab = request.query_parameters.fetch("node_tab", "summary") %>
<% node_id = node["id"] || local_assigns[:node_id] %>
<% gpu_entries = Array(node.dig("system", "gpus") || node.dig("data", "gpus")) %>
<% location = [node.dig("location", "city"), node.dig("location", "country")].compact.reject(&:blank?).join(", ") %>
<% ram_value = node.dig("system", "memory", "size") || node.dig("system", "memory") || node.dig("data", "memory_size") || node.dig("system", "ram") %>
<% formatted_ram = if ram_value.is_a?(Numeric) && ram_value > 1024
  "#{(ram_value.to_f / 1024 / 1024 / 1024).round} GB"
elsif ram_value.present?
  "#{ram_value} GB"
else
  "—"
end %>
<% rows = [
  ["State", node["state"] || node.dig("status") || "—"],
  ["IP", node["ip"] || node["public_ip"] || "—"],
  ["Location", location.presence || "—"],
  ["CPU", node.dig("data", "cpu_model_name") || node.dig("system", "cpu_model_name") || node.dig("system", "cpu") || "—"],
  ["Cores", node.dig("data", "cpu_cores") || node.dig("system", "cpu_cores") || "—"],
  ["RAM", formatted_ram],
  ["CUDA", node.dig("data", "cuda_version") || node.dig("system", "cuda_version") || "—"],
  ["OS", node.dig("data", "os_version") || node.dig("system", "os") || "—"],
  ["Driver", node.dig("data", "gpu_driver_version") || node.dig("system", "gpu_driver_version") || "—"],
  ["Uptime", playground_format_duration(node.dig("data", "uptime") || node["uptime"])],
  ["GPU vendor", node.dig("data", "gpu_vendor") || gpu_entries.first&.dig("vendor") || "—"]
] %>

<div class="space-y-4 rounded-xl border border-slate-800 bg-slate-900 p-5">
  <div class="flex items-center justify-between gap-4">
    <div class="min-w-0">
      <h2 class="text-sm font-semibold text-slate-100">Node #<%= node_id %></h2>
      <code class="text-[11px] text-cyan-500">octa_client.nodes.find(<%= node_id %>)</code>
    </div>
    <% if local_assigns[:close_path].present? %>
      <%= link_to "Close detail", close_path, class: "text-xs text-slate-500 transition-colors hover:text-slate-300" %>
    <% end %>
  </div>

  <div class="flex gap-1 border-b border-slate-800 pb-0">
    <% {"summary" => "Summary", "raw" => "Raw JSON"}.each do |value, label| %>
      <%= link_to label,
                  playground_query_url(:node_tab, value),
                  class: "px-3 py-1.5 text-xs transition-colors #{node_tab == value ? 'border-b-2 border-cyan-500 text-cyan-400 -mb-px' : 'text-slate-500 hover:text-slate-300'}" %>
    <% end %>
  </div>

  <% if node_tab == "raw" %>
    <%= render "playground/shared/json_viewer", data: node %>
  <% else %>
    <div class="space-y-0.5">
      <% rows.each do |label, value| %>
        <div class="flex items-center justify-between gap-4 border-b border-slate-800/60 py-2 text-xs">
          <span class="shrink-0 text-slate-500"><%= label %></span>
          <span class="min-w-0 break-words text-right font-mono text-slate-300"><%= value %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
