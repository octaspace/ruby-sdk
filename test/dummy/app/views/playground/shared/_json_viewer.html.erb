<% max_height = local_assigns.fetch(:max_height, "h-[42rem]") %>

<div class="relative rounded-lg border border-slate-800 bg-slate-950" data-json-viewer>
  <button type="button" data-copy-json data-label="Copy" data-copied-label="Copied!" class="absolute right-2 top-2 z-10 rounded px-2 py-1 text-xs text-slate-500 transition-colors hover:bg-slate-800 hover:text-slate-300">
    Copy
  </button>
  <pre class="overflow-auto p-4 font-mono text-xs leading-relaxed text-slate-200 whitespace-pre-wrap break-all <%= max_height %>"><%= playground_json_html(data) %></pre>
</div>
