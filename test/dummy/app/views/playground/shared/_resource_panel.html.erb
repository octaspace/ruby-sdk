<% tab_param = local_assigns.fetch(:tab_param, :tab).to_s %>
<% current_tab = request.query_parameters.fetch(tab_param, local_assigns.fetch(:default_tab, "formatted")) %>
<% locked = local_assigns.fetch(:locked, false) %>
<% error = local_assigns[:error] %>
<% empty_copy = local_assigns.fetch(:empty_copy, "No data available.") %>
<% locked_copy = local_assigns.fetch(:locked_copy, "Enter an API key in the sidebar to load this resource") %>
<% badge = local_assigns[:badge] %>
<% has_data = playground_present?(data) %>

<div class="space-y-4 rounded-xl border border-slate-800 bg-slate-900 p-5">
  <div class="flex items-start justify-between">
    <div>
      <h2 class="text-sm font-semibold text-slate-100"><%= title %></h2>
      <% if hook.present? %>
        <code class="mt-0.5 text-[11px] text-cyan-500"><%= hook %></code>
      <% end %>
    </div>

    <% if badge.present? %>
      <span class="shrink-0 rounded-full bg-slate-800 px-2 py-0.5 text-[10px] font-medium text-slate-300"><%= badge %></span>
    <% end %>
  </div>

  <% if locked %>
    <div class="flex items-center gap-2 rounded-lg border border-slate-800 bg-slate-950/60 px-4 py-5 text-xs text-slate-500">
      <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V7a4.5 4.5 0 0 0-9 0v3.5M5 10.5h14a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8.5a1 1 0 0 1 1-1z" />
      </svg>
      <span><%= locked_copy %></span>
    </div>
  <% elsif error.present? %>
    <%= render "playground/shared/error_card", error: error %>
  <% elsif has_data %>
    <div class="flex gap-1 border-b border-slate-800 pb-0">
      <% {"formatted" => "Formatted", "raw" => "Raw JSON"}.each do |value, label| %>
        <%= link_to label,
                    playground_query_url(tab_param, value),
                    class: "px-3 py-1.5 text-xs transition-colors #{current_tab == value ? 'border-b-2 border-cyan-500 text-cyan-400 -mb-px' : 'text-slate-500 hover:text-slate-300'}" %>
      <% end %>
    </div>

    <% if current_tab == "raw" %>
      <%= render "playground/shared/json_viewer", data: data, max_height: local_assigns.fetch(:raw_max_height, "h-[42rem]") %>
    <% else %>
      <%= formatted %>
    <% end %>
  <% else %>
    <div class="rounded-lg border border-dashed border-slate-800 bg-slate-950/40 px-4 py-6 text-center text-sm text-slate-500">
      <%= empty_copy %>
    </div>
  <% end %>
</div>
