<% network_data = @network.respond_to?(:data) ? @network.data : nil %>
<% profile_data = @profile.respond_to?(:data) ? @profile.data : nil %>
<% balance_data = @balance.respond_to?(:data) ? @balance.data : nil %>
<% network_error = @network if @network.is_a?(OctaSpace::Error) %>
<% profile_error = @profile if @profile.is_a?(OctaSpace::Error) %>
<% balance_error = @balance if @balance.is_a?(OctaSpace::Error) %>
<% profile_hash = profile_data || {} %>
<% balance_hash = balance_data || {} %>
<% balance_value = balance_data && (balance_hash["balance"] || balance_hash["amount"] || balance_hash.values.first) %>
<% account_formatted = capture do %>
  <div class="space-y-0.5">
    <div class="flex items-center justify-between gap-4 border-b border-slate-800/60 py-2 text-xs">
      <span class="text-slate-500">Account UUID</span>
      <span class="min-w-0 break-all text-right font-mono text-slate-300"><%= profile_hash["account_uuid"] || profile_hash.dig("account", "uuid") || "—" %></span>
    </div>
    <div class="flex items-center justify-between gap-4 border-b border-slate-800/60 py-2 text-xs">
      <span class="text-slate-500">Email</span>
      <span class="min-w-0 break-all text-right font-mono text-slate-300"><%= profile_hash["email"] || profile_hash.dig("account", "email") || "—" %></span>
    </div>
    <div class="flex items-center justify-between gap-4 border-b border-slate-800/60 py-2 text-xs">
      <span class="text-slate-500">Avatar</span>
      <span class="min-w-0 break-all text-right font-mono text-slate-300"><%= profile_hash["avatar"] || "—" %></span>
    </div>
  </div>
<% end %>
<% balance_formatted = capture do %>
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="rounded-lg border border-slate-800 bg-slate-950/70 p-4">
      <div class="text-[10px] uppercase tracking-wider text-slate-500">Balance</div>
      <div class="mt-2 break-all text-base font-semibold text-slate-100"><%= balance_value || "—" %></div>
    </div>
    <div class="rounded-lg border border-slate-800 bg-slate-950/70 p-4">
      <div class="text-[10px] uppercase tracking-wider text-slate-500">Currency</div>
      <div class="mt-2 break-all text-base font-semibold text-slate-100"><%= balance_hash["currency"] || balance_hash["unit"] || "OCTA" %></div>
    </div>
  </div>
<% end %>

<div class="w-full max-w-full space-y-6">
  <div>
    <h1 class="text-lg font-semibold text-slate-100">Dashboard</h1>
    <p class="mt-1 text-sm text-slate-500">
      Account health check. Demonstrates <code class="text-cyan-400">octa_client</code> resource calls in the Rails dummy app with runtime real/mock transport switching.
    </p>
  </div>

  <div class="flex flex-wrap items-center gap-3 rounded-lg border border-slate-800 bg-slate-900 px-4 py-3 text-sm">
    <span class="h-2 w-2 rounded-full <%= playground_api_key_present? ? 'bg-emerald-500' : 'bg-slate-600' %>"></span>
    <span class="text-slate-400">
      <% if playground_mock_active? %>
        Mock transport active —
        <span class="font-mono text-slate-300"><%= playground_transport_label %></span>
      <% elsif playground_api_key_present? %>
        API key set —
        <span class="font-mono text-slate-300"><%= playground_config.urls.first %></span>
      <% else %>
        No API key — enter one in the sidebar to test authenticated endpoints
      <% end %>
    </span>
    <% if playground_mock_active? %>
      <span class="ml-auto rounded bg-amber-500/15 px-2 py-0.5 text-[11px] font-medium text-amber-400">Mock: <%= playground_mock_scenario %></span>
    <% elsif playground_config.keep_alive? %>
      <span class="ml-auto rounded bg-cyan-500/15 px-2 py-0.5 text-[11px] font-medium text-cyan-400">Keep-Alive</span>
    <% end %>
  </div>

  <div class="space-y-4 rounded-xl border border-slate-800 bg-slate-900 p-5">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="flex items-center gap-2">
          <h2 class="text-sm font-semibold text-slate-100">Network Stats</h2>
          <span class="rounded-full bg-emerald-500/20 px-2 py-0.5 text-[10px] font-medium text-emerald-400">public</span>
        </div>
        <code class="mt-0.5 text-[11px] text-cyan-500">octa_client.network.info</code>
      </div>
      <%= link_to "Open", playground_network_path, class: "rounded border border-slate-700 px-2.5 py-1 text-xs text-slate-400 transition-colors hover:border-slate-600 hover:text-slate-200" %>
    </div>

    <% if network_error %>
      <%= render "playground/shared/error_card", error: network_error, max_height: "max-h-40" %>
    <% elsif network_data %>
      <%= render "playground/shared/json_viewer", data: network_data, max_height: "max-h-40" %>
    <% else %>
      <div class="rounded-lg border border-dashed border-slate-800 bg-slate-950/40 px-4 py-6 text-center text-sm text-slate-500">No network payload available.</div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <%= render "playground/shared/resource_panel",
               title: "Account",
               hook: "octa_client.accounts.profile",
               data: profile_data,
               error: profile_error,
               locked: !playground_api_key_present?,
               tab_param: :account_tab,
               empty_copy: "Account data is unavailable.",
               locked_copy: "Enter an API key in the sidebar to load this resource",
               formatted: account_formatted %>

    <%= render "playground/shared/resource_panel",
               title: "Balance",
               hook: "octa_client.accounts.balance",
               data: balance_data,
               error: balance_error,
               locked: !playground_api_key_present?,
               tab_param: :balance_tab,
               empty_copy: "Balance data is unavailable.",
               locked_copy: "Enter an API key in the sidebar to load this resource",
               formatted: balance_formatted %>
</div>
</div>
